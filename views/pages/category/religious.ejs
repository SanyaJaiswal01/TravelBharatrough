    <% layout("/layouts/boilerplate") %>
<div>

    <img class="place-top" src="https://wallpapercave.com/wp/wp7135785.jpg" alt="state-image" />
    <br>
    <H1 class="center-text" style="color: brown;">RELIGIOUS</H1>

<div class="mt-4">
    <div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-2">
        <% for(place of allPlace){ %>
            <% if(place.category=="religious"){ %>    
            <div class="card col place-card">
                <img src="<%= place.image %>" alt="state-image" style="height:15rem;"  class="place-card-img"/>
                <div class="card-body">
                <p class="card-text">
                <%= place.title %> <br>
                <b>City:<%= place.city %></b> <br>
                Location: <%= place.location %> <br>
               </p>
               </div>
                <br>
                </div>
           <% } %>       
        <% } %>
    </div>
</div>

</div>
